# Credenciales de los proxies Bright Data (o proveedor compatible con sticky sessions).
# Copiar este archivo a shared/.env.proxy y rellenar con las credenciales reales.
# Este archivo es cargado automáticamente por proxy_config.py al arrancar cada worker.
# NUNCA subir shared/.env.proxy al repositorio (está en .gitignore).
#
# Asignación de proxies por worker:
#   SCRAPER_WORKER_ID=1  →  PROXY_1_*
#   SCRAPER_WORKER_ID=2  →  PROXY_2_*
#   SCRAPER_WORKER_ID=3  →  PROXY_3_*
#   Sin worker ID o ID fuera de rango → rota cíclicamente por el pool disponible

PROXY_1_HOST=brd.superproxy.io
PROXY_1_PORT=33335
PROXY_1_LOGIN=brd-customer-XXXX-zone-residential_proxy1-country-es
PROXY_1_PASS=XXXXXXXXXX

PROXY_2_HOST=brd.superproxy.io
PROXY_2_PORT=33335
PROXY_2_LOGIN=brd-customer-XXXX-zone-residential_proxy2-country-es
PROXY_2_PASS=XXXXXXXXXX

PROXY_3_HOST=brd.superproxy.io
PROXY_3_PORT=33335
PROXY_3_LOGIN=brd-customer-XXXX-zone-residential_proxy3-country-es
PROXY_3_PASS=XXXXXXXXXX
